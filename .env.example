# 비우면 MOCK 모드(키 없이 전체 동작), 채우면 LIVE 모드
GEMINI_API_KEY=""

# 다중 키를 쓰려면 아래 중 하나 (429 발생 시 자동 로테이션)
# GEMINI_API_KEYS="key1,key2,key3"
# GEMINI_API_KEY_1=""
# GEMINI_API_KEY_2=""

# Pro 모델은 무료 티어에서 제외됨 — Flash / Flash-Lite 권장
GEMINI_NARRATIVE_MODEL=gemini-2.5-flash
GEMINI_EXTRACT_MODEL=gemini-2.5-flash-lite

PORT=3000
