# Gemini API key. Get one at https://aistudio.google.com/apikey
# If left empty, the server runs in MOCK mode (no real API calls) so you can
# still verify the full turn loop end-to-end.
GEMINI_API_KEY="이곳에 API 키를 입력하세요"

# Optional overrides
GEMINI_NARRATIVE_MODEL=gemini-3.1-flash-lite
GEMINI_EXTRACT_MODEL=gemini-3.1-flash-lite
PORT=3000
